# Hyphrki Orchestrator Production Environment Configuration
NODE_ENV=production

# Database Configuration
DB_PASSWORD=your-secure-database-password-here
DATABASE_URL=postgresql://hyphrki_user:your-secure-database-password-here@postgres:5432/hyphrki_platform

# Redis Configuration
REDIS_PASSWORD=your-secure-redis-password-here
REDIS_URL=redis://:your-secure-redis-password-here@redis:6379

# JWT Configuration
JWT_SECRET=your-super-secure-jwt-secret-key-minimum-64-characters-long-for-production-security

# N8N Configuration
N8N_API_KEY=your-secure-n8n-api-key-here
N8N_BASIC_AUTH_USER=n8nuser
N8N_BASIC_AUTH_PASSWORD=your-secure-n8n-basic-auth-password-here
N8N_ENCRYPTION_KEY=your-secure-n8n-encryption-key-minimum-32-characters-long

# Inter-server Communication
INTER_SERVER_API_KEY=your-secure-inter-server-api-key-for-service-communication

# Application URLs
NEXT_PUBLIC_API_URL=https://your-domain.com
NEXT_PUBLIC_ORCHESTRATOR_URL=https://your-domain.com/orchestrator
NEXT_PUBLIC_ORCHESTRATOR_WS_URL=wss://your-domain.com/n8n

# Security Settings
CORS_ORIGIN=https://your-domain.com
SESSION_SECRET=your-super-secure-session-secret-key-minimum-32-characters-long

# File Upload Settings
MAX_FILE_SIZE=10485760
UPLOAD_DIR=/app/uploads

# Logging
LOG_LEVEL=info
LOG_FILE=/app/logs/hyphrki.log

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
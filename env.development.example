# Hyphrki Orchestrator Development Environment Configuration
NODE_ENV=development

# Database Configuration
DB_PASSWORD=dev_password_123
DATABASE_URL=postgresql://hyphrki_user:dev_password_123@localhost:5432/hyphrki_platform

# Redis Configuration
REDIS_PASSWORD=dev_redis_password_123
REDIS_URL=redis://:dev_redis_password_123@localhost:6379

# JWT Configuration
JWT_SECRET=development-jwt-secret-key-not-for-production-use-only

# N8N Configuration
N8N_API_KEY=dev_n8n_api_key_123
N8N_BASIC_AUTH_USER=n8nuser
N8N_BASIC_AUTH_PASSWORD=dev_n8n_password_123
N8N_ENCRYPTION_KEY=development-n8n-encryption-key-32-chars

# Inter-server Communication
INTER_SERVER_API_KEY=dev_inter_server_api_key_123

# Application URLs
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:5678
NEXT_PUBLIC_ORCHESTRATOR_WS_URL=ws://localhost:5679

# Security Settings
CORS_ORIGIN=http://localhost:3000
SESSION_SECRET=development-session-secret-key-32-chars

# File Upload Settings
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/hyphrki.log

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
